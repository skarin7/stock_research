# Anthropic API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=


# Google Gemini API — get free key from https://aistudio.google.com (1500 req/day free)
GEMINI_API_KEY=

# Telegram Bot — get token from @BotFather, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stock universe: nifty50 | nifty100 | nifty200 | nifty500 | screener (default: nifty200)
STOCK_UNIVERSE=nifty200

# Screener.in credentials — only needed if STOCK_UNIVERSE=screener
SCREENER_EMAIL=
SCREENER_PASSWORD=

# Screener.in saved screen ID (the number in the URL: screener.in/screens/XXXXXX/)
SCREENER_SCREEN_ID=
SCREENER_SCREEN_SLUG=good-pe-stocks

GROWW_TOTP_TOKEN=
GROWW_TOTP_SECRET=