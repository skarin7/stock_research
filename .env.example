# Anthropic API — get from https://console.anthropic.com
ANTHROPIC_API_KEY=

# LLM provider: anthropic (default) | openrouter
# OpenRouter hosts cheap reasoning models (DeepSeek/Qwen/Kimi) ~10-50x cheaper.
LLM_PROVIDER=anthropic
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_SCORING_MODEL=deepseek/deepseek-chat
OPENROUTER_REPORT_MODEL=deepseek/deepseek-chat


# Google Gemini API — get free key from https://aistudio.google.com (1500 req/day free)
GEMINI_API_KEY=

# Tavily web search — macro_search chat tool grounding. Free tier ~1000/mo, no card.
# Get key from https://app.tavily.com
TAVILY_API_KEY=

# Telegram Bot — get token from @BotFather, then visit:
# https://api.telegram.org/bot<TOKEN>/getUpdates  to find your chat_id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Stock universe: nifty50 | nifty100 | nifty200 | nifty500 | screener (default: nifty200)
STOCK_UNIVERSE=nifty200

# Screener.in credentials — only needed if STOCK_UNIVERSE=screener
SCREENER_EMAIL=
SCREENER_PASSWORD=

# Screener.in saved screen ID (the number in the URL: screener.in/screens/XXXXXX/)
SCREENER_SCREEN_ID=
SCREENER_SCREEN_SLUG=good-pe-stocks

GROWW_TOTP_TOKEN=
GROWW_TOTP_SECRET=
GROWW_API_KEY=
GROWW_API_SECRET=

# ─────────────────────────────────────────────────────────────────────────────
# Multi-agent flow (run_agents.py)
# ─────────────────────────────────────────────────────────────────────────────

# Active profile — controls which agents run and whether live trading is enabled.
#   research  →  score + report + Telegram alert only (safe, default)
#   paper     →  full pipeline with simulated fills + stop-loss monitoring
#   live      →  real broker orders via Groww (requires Groww API keys + human approval)
AGENT_PROFILE=research

KILL_SWITCH=false               # true OR the flag file present → halts everything

# Human-approval (HITL) for live entries. Cross-process resume (daily job suspends,
# webhook/CLI resumes) REQUIRES Postgres — without DATABASE_URL the suspended run
# can't be resumed and the Telegram /approve does nothing.
APPROVAL_TIMEOUT_SEC=900        # unapproved proposals expire after this
DATABASE_URL=                   # postgres://… — required for live HITL + cross-process resume

# Risk limits (portfolio sizing + stops)
TRADING_CAPITAL_INR=100000
MAX_OPEN_POSITIONS=5
MAX_POSITION_PCT=0.10           # max fraction of capital per position
MAX_SECTOR_PCT=0.30
STOP_LOSS_PCT=0.05
MIN_CONVICTION_TO_TRADE=0.6
BLOCK_NEAR_EARNINGS=true

# ─── Auto-execution guardrails (protective EXITS only; never opens risk) ───────
# Only active when AGENT_PROFILE=live. Auto-sells a stopped position during
# monitoring. Refusal on any guard → keep position + alert a human (HITL).
AUTO_TRADE_ALLOWLIST=           # comma-sep symbols eligible, e.g. RELIANCE,TCS (empty = none)
MAX_DAILY_NOTIONAL=50000        # ₹ ceiling across all auto orders per day
MAX_ORDERS_PER_DAY=10
AUTO_TRADE_WINDOW=09:20-15:20   # IST HH:MM-HH:MM; skip the open/close minutes

# ─── Conversational chat agent (Telegram webhook service) ──────────────────────
ENABLE_CHAT_AGENT=false
CHAT_MODEL=                     # empty → falls back to REPORT_MODEL
TELEGRAM_WEBHOOK_SECRET=        # X-Telegram-Bot-Api-Secret-Token header check
MAX_CHAT_TOOL_CALLS=8
MAX_CHAT_TURN_COST_USD=0.25
SNAPSHOT_STALE_DAYS=3
MACRO_SEARCH_MAX_RESULTS=5