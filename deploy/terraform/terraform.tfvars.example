# Infra-only vars — no app secrets here.
# App config (API keys, tokens, DB URL, Groww creds etc.) lives in deploy/prod.env (gitignored).
# Setup: cp .env.example deploy/prod.env  →  fill in prod values.

# --- GCP (defaults already match the project; override if needed) ---
# project_id = "gen-lang-client-0533266855"
# region     = "asia-south1"
# vm_zone    = "asia-south1-a"

# --- VM ---
vm_ssh_pub_key = "ssh-ed25519 AAAA..."

# --- Instance schedule (market hours only; set false to keep VM always-on) ---
# enable_schedule = false
