# Copy to terraform.tfvars and fill in. terraform.tfvars is gitignored.
# Alternatively export TF_VAR_<name> environment variables (preferred in CI).

# --- GCP (defaults already match your project; override if needed) ---
# project_id = "gen-lang-client-0533266855"
# region     = "asia-south1"

# --- Required (keep even if using OpenRouter — chat agent falls back to Anthropic) ---
anthropic_api_key = "sk-ant-..."

# --- Durable state: Neon serverless Postgres connection string ---
# Create a free project at https://neon.tech, copy the pooled connection string.
# Leave empty to run research-only with in-memory state (no resumable runs).
database_url = "postgresql://user:pass@ep-xxx.aws.neon.tech/neondb?sslmode=require"

# --- Observability: Langfuse Cloud (managed, free tier) ---
# Create a project at https://cloud.langfuse.com, copy the API keys.
langfuse_public_key = "pk-lf-..."
langfuse_secret_key = "sk-lf-..."
langfuse_host       = "https://cloud.langfuse.com"
# Optional batch metrics push (else leave empty — Langfuse covers LLM obs):
# prometheus_pushgateway_url = "https://pushgateway.example.com"

# --- Market data / news / delivery (optional but recommended) ---
gemini_api_key       = ""
groww_totp_token     = ""
groww_totp_secret    = ""
groww_token_enc_key  = ""  # passphrase to encrypt the cached Groww token at rest; generate: python -c "import secrets;print(secrets.token_urlsafe(32))"
telegram_bot_token   = ""
telegram_chat_id     = ""
screener_email       = ""
screener_password    = ""
screener_screen_id   = ""
screener_screen_slug = ""

stock_universe = "nifty200"
agent_profile  = "research"  # research | paper | live

# --- LLM provider: "anthropic" or "openrouter" (10-50x cheaper, recommended) ---
# OpenRouter routes to DeepSeek/Qwen etc. Anthropic Batch API discount does NOT apply via OpenRouter.
llm_provider             = "openrouter"   # change to "anthropic" to use Haiku/Sonnet directly
openrouter_api_key       = "sk-or-..."
openrouter_scoring_model = "deepseek/deepseek-chat"
openrouter_report_model  = "deepseek/deepseek-chat"

# --- Chat agent: Telegram webhook Cloud Run Service (opt-in, scales to zero = no idle cost) ---
# enable_chat_agent       = true
# telegram_webhook_secret = "some-random-string"   # pick any secret, used to verify Telegram calls
# After deploy, register the webhook once:
#   python scripts/set_webhook.py https://<chat-service-url>/telegram/webhook

# --- Monitoring: second job + market-hours scheduler (opt-in) ---
# enable_monitoring = true
# monitor_schedule  = "*/5 3-10 * * 1-5"   # ~every 5 min, 08:30-16:25 IST, Mon-Fri
